# ProcessSutra — Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env with real secrets to version control.

# ──────────────────────────────────────────────
# REQUIRED — App will not start without these
# ──────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_PG_PASSWORD@localhost:5432/processsutra

# MongoDB connection string
MONGODB_URI=mongodb://admin:YOUR_MONGO_PASSWORD@localhost:27017/processsutra?authSource=admin
MONGODB_DB=processsutra

# Session secret — minimum 32 characters, use: openssl rand -hex 32
SESSION_SECRET=

# Google OAuth (for user authentication)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.processsutra.com/api/auth/google/callback

# ──────────────────────────────────────────────
# DOCKER COMPOSE — Used by docker-compose.yml
# ──────────────────────────────────────────────

POSTGRES_PASSWORD=
MONGO_PASSWORD=
REDIS_PASSWORD=

# ──────────────────────────────────────────────
# OPTIONAL — Features that work without these
# ──────────────────────────────────────────────

# Domain for IP→domain redirect middleware
DOMAIN_NAME=processsutra.com

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://processsutra.com,https://www.processsutra.com

# Flow API keys (JSON map of orgId→key, or single key for all)
# FLOW_API_KEYS={"org_123":"key_abc"}
# FLOW_API_KEY=

# Cookie settings (only change for debugging)
# COOKIE_SECURE=true
# INSECURE_COOKIES=false

# Error monitoring (Sentry, etc.)
# ERROR_MONITORING_ENABLED=false
# ERROR_MONITORING_SERVICE=sentry
# ERROR_MONITORING_DSN=

# Dev-only flags (never set in production)
# DISABLE_DEV_AUTH=true
# DEBUG_ROUTES=true

# PM2 deployment target
DEPLOY_HOST=YOUR_SERVER_IP
